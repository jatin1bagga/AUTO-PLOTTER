# REQUIRED: Google AI Studio API key for Gemini LLM calls and embeddings
# Get yours free at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyAyaYINIJUu25LHjQgnvFjQhnnZeewmJXg

# OPTIONAL: Gemini model to use (default: gemini-2.0-flash for speed & cost)
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# OPTIONAL: LangSmith observability (set to 'true' to enable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=data-science-copilot

# OPTIONAL: Max retries for the self-correcting code loop (default: 3)
MAX_RETRIES=3
